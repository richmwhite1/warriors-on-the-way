# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Never expose to client

# ─── App ──────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000  |  Production: https://warriorsontheway.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── n8n (Phase 4) ────────────────────────────────────────────────────────────
# Your self-hosted n8n instance on Oracle Free ARM VM
N8N_WEBHOOK_BASE_URL=https://n8n.yourdomain.com/webhook
N8N_WEBHOOK_SECRET=your-webhook-secret  # Used to verify inbound webhook calls

# ─── Resend (Phase 4) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=hello@warriorsontheway.com

# ─── YouTube Data API (Phase 2) ───────────────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-api-key
